#!/usr/bin/env python3
import argparse
import base64
import os
import re
import shutil
import subprocess
import sys
import urllib.parse
from typing import Dict, List, Optional


def load_dotenv(path: str = ".env") -> Dict[str, str]:
    data: Dict[str, str] = {}
    if not os.path.isfile(path):
        return data
    for line in open(path, "r", encoding="utf-8", errors="ignore"):
        s = line.strip()
        if not s or s.startswith("#"):
            continue
        if s.startswith("export "):
            s = s[len("export "):]
        if "=" not in s:
            continue
        k, v = s.split("=", 1)
        k = k.strip()
        v = v.strip().strip('"').strip("'")
        data[k] = v
    return data


def run_cmd(cmd: List[str]) -> str:
    try:
        return subprocess.check_output(cmd, stderr=subprocess.DEVNULL, text=True).strip()
    except Exception:
        return ""


def ip_from_iface(iface: str) -> Optional[str]:
    out = run_cmd(["ip", "-4", "addr", "show", iface])
    m = re.search(r"inet\s+(\d+\.\d+\.\d+\.\d+)/(\d+)", out)
    return m.group(1) if m else None


def detect_lhost() -> Optional[str]:
    tun = ip_from_iface("tun0")
    if tun:
        return tun

    out = run_cmd(["ip", "-4", "-o", "addr", "show", "up"])
    for line in out.splitlines():
        parts = line.split()
        if len(parts) < 4:
            continue
        iface = parts[1]
        if iface == "lo":
            continue
        cidr = parts[3]
        ip = cidr.split("/")[0]
        if ip.startswith("127."):
            continue
        return ip
    return None


def colorize(text: str, code: str, use_color: bool) -> str:
    if not use_color:
        return text
    return f"\033[{code}m{text}\033[0m"


