def render_technique(t: Technique, explain: bool, quiet: bool, use_color: bool) -> str:
    lines: List[str] = []
    if not quiet:
        lines.append(color(f"[{t.id}] {t.title}", "36", use_color))
        lines.append(color(f"Platform: {t.platform} | Tags: {', '.join(t.tags)}", "90", use_color))
        lines.append(t.summary)
        lines.append("")

    for idx, st in enumerate(t.steps, 1):
        prefix = f"{idx:02d}. "
        label = side_label(st.side)
        if quiet:
            if st.side in {"attacker", "victim"}:
                lines.append(st.cmd)
            continue
        side_col = "33" if st.side == "attacker" else ("32" if st.side == "victim" else "35")
        line = f"{prefix}{label:<9} {st.cmd}"
        if st.warn:
            line = color("[WARN] ", "31", use_color) + line
        lines.append(color(line, side_col, use_color))
        if explain and st.explain:
            lines.append(f"    - {st.explain}")

    return "\n".join(lines)


def main() -> int:
    env = load_dotenv()
    auto_lhost = env.get("tun0_ip") or detect_lhost() or ""
    target = env.get("target", "<target>")
    box = env.get("box", "-")
    rows, cols = terminal_size()

    p = argparse.ArgumentParser(description="upgrade-shell: shell stabilization assistant for HTB/CPTS/OSCP workflows")
    p.add_argument("technique", nargs="?", help="Technique ID")
    p.add_argument("--list", action="store_true", help="List available techniques")
    p.add_argument("--search", default="", help="Search techniques by keyword")
    p.add_argument("--flow", default="", help="Alias of technique ID for step-by-step output")
    p.add_argument("--platform", choices=["linux", "windows", "mixed", "all"], default="all", help="Filter by platform")
    p.add_argument("--lhost", default=auto_lhost, help="Callback IP (defaults: .env tun0_ip, tun0, active interface)")
    p.add_argument("--lport", type=int, default=int(os.getenv("UPGRADE_SHELL_DEFAULT_PORT", "4444")), help="Callback/listener port")
    p.add_argument("--target", default=target, help="Target host/IP (default from .env target)")
    p.add_argument("--rows", type=int, default=rows, help="Terminal rows for resize commands")
    p.add_argument("--cols", type=int, default=cols, help="Terminal columns for resize commands")
    p.add_argument("--quiet", action="store_true", help="Output commands only")
    p.add_argument("--copy", type=int, default=0, help="Copy Nth command from output (1-based)")
    p.add_argument("--explain", action="store_true", help="Beginner-friendly explanations")
    p.add_argument("--no-color", action="store_true", help="Disable ANSI color")
    p.add_argument("--menu", action="store_true", help="Interactive menu mode")

    args = p.parse_args()
    use_color = sys.stdout.isatty() and not args.no_color and not args.quiet

    items = techniques(args.lhost, args.lport, args.target, args.rows, args.cols)

    if args.platform != "all":
        items = [t for t in items if t.platform == args.platform]

    if args.list:
        for t in items:
            print(f"{t.id:<24} {t.platform:<8} {t.title}")
        return 0

    if args.search:
        q = args.search.lower()
        for t in items:
            blob = " ".join([t.id, t.title, t.summary, " ".join(t.tags)]).lower()
            if q in blob:
                print(f"{t.id:<24} {t.platform:<8} {t.title}")
        return 0

    if args.menu:
        if not sys.stdin.isatty():
            print("[!] Interactive mode requires a TTY", file=sys.stderr)
            return 1
        print(color("upgrade-shell interactive menu", "36", use_color))
        for i, t in enumerate(items, 1):
            print(f"{i:02d}) {t.id:<24} {t.title}")
        sel = input("Select technique number: ").strip()
        if not sel.isdigit() or not (1 <= int(sel) <= len(items)):
            print("[!] Invalid selection", file=sys.stderr)
            return 1
        chosen = items[int(sel) - 1]
    else:
        wanted = args.flow or args.technique
        if not wanted:
            p.print_help()
            return 1
        chosen = next((t for t in items if t.id == wanted), None)
        if not chosen:
            print(f"[!] Unknown technique: {wanted}", file=sys.stderr)
            print("[i] Use --list to view available technique IDs", file=sys.stderr)
            return 1

    header = f"upgrade-shell | technique={chosen.id} | box={box} | target={args.target}"
    if not args.quiet:
        print(color(header, "36", use_color))
        print(color("=" * len(header), "36", use_color))
        print()

    output = render_technique(chosen, explain=args.explain, quiet=args.quiet, use_color=use_color)
    print(output)

    if args.copy > 0:
        cmds = [s.cmd for s in chosen.steps if s.side in {"attacker", "victim"}]
        if args.copy > len(cmds):
            print(f"[!] copy index out of range (1-{len(cmds)})", file=sys.stderr)
            return 1
        copied = copy_clipboard(cmds[args.copy - 1])
        if not args.quiet:
            if copied:
                print(color(f"\n[+] Copied command #{args.copy} via {copied}", "32", use_color))
            else:
                print(color("\n[!] Clipboard tool not found (xclip/xsel/wl-copy)", "33", use_color))

    return 0


if __name__ == "__main__":
    sys.exit(main())
